---
---
<section id="cta" class="section-padding">
  <div class="glass rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden">
    <!-- Animated background element -->
    <div class="absolute -top-1/2 -left-1/4 w-full h-full bg-[#2997ff]/10 blur-[120px] rounded-full animate-pulse"></div>
    <div class="absolute -bottom-1/2 -right-1/4 w-full h-full bg-blue-900/10 blur-[120px] rounded-full animate-pulse delay-1000"></div>
    
    <div class="relative z-10">
      <h2 class="text-4xl md:text-7xl font-bold mb-8 tracking-tighter text-gradient">Lleva tu experiencia al siguiente nivel.</h2>
      <p class="text-[#a1a1a6] text-xl md:text-2xl mb-12 max-w-3xl mx-auto leading-relaxed">
        Elige tu próximo iPhone y personalízalo con los mejores accesorios originales del mercado. Financiación en cuotas y envío Pro.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a href="#" class="px-12 py-5 bg-white text-black rounded-full font-bold text-xl hover:bg-[#f5f5f7] transition-all transform hover:scale-105">
          Comprar ahora
        </a>
        <a href="#" class="px-12 py-5 border border-white/20 text-white rounded-full font-bold text-xl hover:bg-white/5 transition-all">
          Ver accesorios
        </a>
      </div>
      <p class="mt-10 text-sm text-[#a1a1a6]">
        *Sujeto a disponibilidad de stock y aprobación crediticia.
      </p>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('#cta .glass', {
    scale: 0.9,
    opacity: 0,
    duration: 1.5,
    ease: 'power4.out',
    scrollTrigger: {
      trigger: '#cta',
      start: 'top 85%',
    }
  });
</script>
