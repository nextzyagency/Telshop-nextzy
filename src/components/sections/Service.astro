---
const benefits = [
  {
    title: "Ecosistema Apple",
    description: "Sincronización perfecta entre tu iPhone, AirPods y MacBook. Todo fluye.",
    icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
  },
  {
    title: "Accesorios Pro",
    description: "Desde fundas MagSafe hasta cargadores ultra-rápidos de alta gama.",
    icon: "M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"
  },
  {
    title: "Soporte Experto",
    description: "Especialistas certificados listos para ayudarte con cualquier configuración.",
    icon: "M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
  }
];
---
<section id="expertos" class="section-padding bg-black">
  <div class="text-center mb-20">
    <h2 class="text-4xl md:text-6xl font-bold mb-6 text-gradient">Expertos en Apple.</h2>
    <p class="text-[#a1a1a6] text-xl max-w-2xl mx-auto">
      No solo vendemos productos, te ayudamos a integrar el mejor ecosistema tecnológico del mundo.
    </p>
  </div>

  <div class="benefits-wrapper grid grid-cols-1 md:grid-cols-3 gap-10">
    {benefits.map((benefit) => (
      <div class="benefit-card glass p-10 rounded-3xl group hover:border-[#2997ff]/50 transition-all duration-500 transform hover:-translate-y-2">
        <div class="w-16 h-16 bg-blue-500/10 text-[#2997ff] rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={benefit.icon} />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">{benefit.title}</h3>
        <p class="text-[#a1a1a6] leading-relaxed text-lg">{benefit.description}</p>
      </div>
    ))}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.benefit-card', {
    opacity: 0,
    y: 60,
    stagger: 0.15,
    duration: 1,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.benefits-wrapper',
      start: 'top 80%',
      toggleActions: 'play none none none',
    },
  });
</script>
