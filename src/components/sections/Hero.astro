---
import { Image } from 'astro:assets';
import heroImage from '../../assets/hero-iphone.png';
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black pt-20">
  <!-- Ambient background glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_50%_50%,#1d1d1f_0%,#000_100%)]"></div>
  
  <div class="container mx-auto px-6 text-center z-10">
    <div id="hero-tag" class="inline-block px-4 py-1.5 rounded-full border border-white/10 bg-white/5 text-sm font-medium text-blue-400 mb-8 opacity-0">
      Tienda Autorizada Premium
    </div>
    
    <h1 id="hero-title" class="text-6xl md:text-8xl font-bold mb-8 tracking-tighter text-gradient opacity-0">
      iPhone 15 Pro.<br/><span class="text-white">Forjado en titanio.</span>
    </h1>
    
    <p id="hero-subtitle" class="text-xl md:text-2xl text-[#a1a1a6] mb-12 max-w-2xl mx-auto opacity-0">
      Conectando calidad y seguridad. Tranquilidad y confianza en cada equipo Apple.
    </p>
    
    <div id="hero-cta" class="flex flex-col sm:flex-row gap-6 justify-center items-center opacity-0">
      <a href="/iphone" class="px-10 py-4 bg-[#2997ff] text-white rounded-full font-semibold hover:bg-[#0077ed] transition-all transform hover:scale-105 shadow-xl shadow-blue-500/20" title="Ver catálogo de iPhones">
        Ver Catálogo iPhone
      </a>
      <a href="#mas-informacion" class="group flex items-center gap-2 text-xl font-medium text-[#2997ff] hover:underline" title="Más información sobre iPhone 15 Pro">
        Más información 
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Visual Element: iPhone Showcase -->
    <div id="hero-image" class="mt-20 relative max-w-5xl mx-auto opacity-0">
      <div class="relative rounded-3xl overflow-hidden shadow-[0_0_50px_rgba(41,151,255,0.15)]">
        <Image 
          src={heroImage} 
          alt="iPhone 15 Pro Titanium" 
          class="w-full h-auto object-cover"
          loading="eager"
          fetchpriority="high"
          title="iPhone 15 Pro Titanium"
        />
      </div>
      <!-- Decorative light beam -->
      <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-3/4 h-32 bg-blue-500/20 blur-[120px] rounded-full"></div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const heroTl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.2 } });
  
  heroTl
    .to('#hero-tag', { opacity: 1, y: 0, startAt: { y: 20 } })
    .to('#hero-title', { opacity: 1, y: 0, startAt: { y: 40 } }, '-=0.8')
    .to('#hero-subtitle', { opacity: 1, y: 0, startAt: { y: 30 } }, '-=1')
    .to('#hero-cta', { opacity: 1, y: 0, startAt: { y: 20 } }, '-=1.1')
    .to('#hero-image', { opacity: 1, y: 0, scale: 1, startAt: { y: 60, scale: 0.95 } }, '-=1');
</script>
