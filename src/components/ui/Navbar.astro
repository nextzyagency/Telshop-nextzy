---
---
<nav class="fixed top-0 left-0 w-full z-50 glass border-b border-white/5">
  <div class="container mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-2xl font-bold text-white tracking-tighter hover:text-[#2997ff] transition-colors" title="Volver al inicio">
      TELSHOP
    </a>
    
    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-[#a1a1a6]">
      <a href="/iphone" class="hover:text-white transition-colors" title="Ver iPhones disponibles">iPhone</a>
      <a href="/audifonos" class="hover:text-white transition-colors" title="Ver audífonos y AirPods">Audífonos</a>
      <a href="/accesorios" class="hover:text-white transition-colors" title="Ver accesorios para Apple">Accesorios</a>
      <a href="/#faq" class="hover:text-white transition-colors" title="Preguntas frecuentes y soporte">Soporte</a>
    </div>

    <div class="flex items-center gap-4">
      <button id="open-cart" class="relative px-5 py-2 bg-white text-black rounded-full text-xs font-bold hover:bg-[#f5f5f7] transition-all flex items-center gap-2">
        <span>Mi Carrito</span>
        <span id="cart-count" class="bg-blue-500 text-white w-5 h-5 rounded-full flex items-center justify-center text-[10px]">0</span>
      </button>
    </div>
  </div>
</nav>

<script>
  import { cartItems } from '../../lib/cartStore';

  function initNavbar() {
    const cartCount = document.getElementById('cart-count');
    const openCartBtn = document.getElementById('open-cart');

    // Limpiar suscripciones previas si fuera necesario (aunque nanostores lo maneja bien)
    cartItems.subscribe((items) => {
      if (!cartCount) return;
      const total = Object.values(items).reduce((acc: any, item: any) => acc + (item?.quantity || 0), 0);
      cartCount.innerText = total.toString();
    });

    openCartBtn?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('toggle-cart'));
    });
  }

  // Ejecutar en cada carga de página (incluyendo navegaciones)
  document.addEventListener('astro:page-load', initNavbar);
</script>
