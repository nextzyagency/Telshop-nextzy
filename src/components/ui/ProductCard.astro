---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  price: string;
  image: string | ImageMetadata;
  tag?: string;
}

const { name, price, image, tag } = Astro.props;
const id = name.toLowerCase().replace(/\s+/g, '-');
const imageSrc = typeof image === 'string' ? image : image.src;
---
<div class="product-card glass p-6 rounded-[2.5rem] flex flex-col group transition-all duration-500 hover:border-[#2997ff]/30">
  <div class="aspect-square rounded-2xl bg-black mb-6 overflow-hidden relative">
    {tag && (
      <span class="absolute top-4 left-4 z-10 px-3 py-1 bg-[#2997ff] text-white text-[10px] font-bold rounded-full uppercase tracking-wider">
        {tag}
      </span>
    )}
    {typeof image === 'string' ? (
      <img 
        src={image} 
        alt={name} 
        title={name}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100" 
      />
    ) : (
      <Image 
        src={image} 
        alt={name} 
        title={name}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100" 
      />
    )}
  </div>
  <div class="flex-grow">
    <h3 class="text-xl font-bold text-white mb-2">{name}</h3>
    <p class="text-2xl font-semibold text-[#f5f5f7] mb-6">{price}</p>
  </div>
  <button 
    class="add-to-cart w-full py-4 bg-white/5 border border-white/10 text-white rounded-2xl font-bold hover:bg-white hover:text-black transition-all"
    data-id={id}
    data-name={name}
    data-price={price}
    data-image={imageSrc}
    title={`Añadir ${name} al carrito`}
  >
    Añadir al carrito
  </button>
</div>

<script>
  import { addCartItem } from '../../lib/cartStore';

  function setupAddToCart() {
    const buttons = document.querySelectorAll('.add-to-cart');
    buttons.forEach(button => {
      button.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const product = {
          id: btn.dataset.id || '',
          name: btn.dataset.name || '',
          price: btn.dataset.price || '',
          image: btn.dataset.image || ''
        };
        addCartItem(product);
        
        // Auto-open cart to show feedback
        document.dispatchEvent(new CustomEvent('toggle-cart'));
      });
    });
  }

  // Eliminar la carga inicial directa y usar solo astro:page-load
  // ya que astro:page-load se dispara tanto en la carga inicial como en navegaciones posteriores.
  document.addEventListener('astro:page-load', setupAddToCart);
</script>
