---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ui/ProductCard.astro';
import Footer from '../components/sections/Footer.astro';

const iphones = [
  { name: "iPhone 15 Pro Max", price: "$1,199", image: "/telshop/imagenes/hero-iphone.png", tag: "Nuevo" },
  { name: "iPhone 15 Pro", price: "$999", image: "/telshop/imagenes/hero-iphone.png", tag: "Nuevo" },
  { name: "iPhone 15 Plus", price: "$899", image: "/telshop/imagenes/hero-iphone.png" },
  { name: "iPhone 15", price: "$799", image: "/telshop/imagenes/hero-iphone.png" },
  { name: "iPhone 14 Pro", price: "$899", image: "/telshop/imagenes/hero-iphone.png", tag: "Oferta" },
  { name: "iPhone 13", price: "$599", image: "/telshop/imagenes/hero-iphone.png" },
];

const seoData = {
  title: "Catálogo iPhone | Telshop",
  description: "Explora los últimos modelos de iPhone 15 Pro, Pro Max y más. Originales con garantía oficial."
};
---

<Layout {...seoData}>
  <main class="pt-32 bg-black min-h-screen">
    <div class="section-padding">
      <div class="mb-16 reveal">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 text-gradient">Línea iPhone.</h1>
        <p class="text-[#a1a1a6] text-xl max-w-2xl">
          Potencia, diseño y el sistema de cámaras más avanzado en un smartphone. Elige tu próximo compañero.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {iphones.map((iphone) => (
          <ProductCard {...iphone} />
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';
  const reveal = document.querySelector('.reveal');
  gsap.from(reveal, { opacity: 0, y: 30, duration: 1, ease: 'power3.out' });
</script>
